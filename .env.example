# Copiar para .env e ajustar caminhos: cp .env.example .env

# UID/GID do host (Linux). Evita ficheiros criados no bind mount com dono root.
USER_ID=1000
GROUP_ID=1000

# Diretório de trabalho no host montado em /home/dev/workspace
WORKSPACE_HOST=./workspace

# Caminho absoluto do clone local de https://github.com/owrasor/dotfiles
DOTFILES_HOST=/caminho/absoluto/para/dotfiles

# Pasta .ssh do host (montagem read-only no contentor)
SSH_DIR=/home/SEU_UTILIZADOR/.ssh

# 1 = durante o build instala Node (NodeSource) e CLIs de IA em /usr/local (imagem mais pesada)
# 0 = imagem slim; instalar depois com: docker compose exec -u root dev /usr/local/bin/install-ai-clis.sh
INSTALL_AI_CLIS=0

# --- Perfil public (ngrok) ---
# Obrigatório ao usar: docker compose --profile public up
NGROK_AUTHTOKEN=
# Serviço e porta *internos* na rede Docker (ex.: app na 3000 dentro do serviço dev)
NGROK_TUNNEL_TARGET=dev:3000

TERM=xterm-256color

# --- CLIs de IA (variáveis típicas; consultar documentação oficial de cada ferramenta) ---
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# QWEN_API_KEY=
# CURSOR_API_KEY=
