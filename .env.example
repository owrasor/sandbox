# Copiar para .env e ajustar caminhos: cp .env.example .env

# UID/GID do host (Linux). Evita ficheiros criados no bind mount com dono root.
USER_ID=1000
GROUP_ID=1000

# Diretório de trabalho no host montado em /home/dev/workspace
WORKSPACE_HOST=./workspace

# Caminho absoluto do clone local de https://github.com/owrasor/dotfiles
DOTFILES_HOST=/caminho/absoluto/para/dotfiles

# Opcional: nome de um ficheiro executável no *topo* do clone de dotfiles (montado em /home/dev/dotfiles).
# Na primeira sessão zsh com sucesso, corre no máximo uma vez; estado em workspace/.sandbox/ (gitignored).
# Apenas [a-zA-Z0-9._-], sem barras. Ver docs/sandbox.md.
# DOTFILES_BOOTSTRAP_SCRIPT=my-bootstrap.sh

# Opcional: qualquer valor não vazio desactiva o hook de bootstrap (CI / depuração).
# SANDBOX_DOTFILES_BOOTSTRAP_SKIP=1

# Pasta .ssh do host (montagem read-only no contentor)
SSH_DIR=/home/SEU_UTILIZADOR/.ssh

# DEPRECATED: `INSTALL_AI_CLIS` já não é lido pelo docker-compose.yml.
# O build do serviço `dev` instala sempre PHP 8.4 + Node 22 (mise) e as CLIs de IA documentadas no README.
# Mantido só para ambientes com `.env` antigo; pode remover esta linha.
# INSTALL_AI_CLIS=

# --- Perfil public (ngrok) ---
# Obrigatório ao usar: docker compose --profile public up
NGROK_AUTHTOKEN=
# Serviço e porta *internos* na rede Docker (ex.: app na 3000 dentro do serviço dev)
NGROK_TUNNEL_TARGET=dev:3000

TERM=xterm-256color

# --- Angie (proxy reverso .test + HTTPS) ---
# Publicação no host: 80 (HTTP) e 443 (HTTPS) — ver docker-compose.yml serviço `angie`.
# Caminho absoluto no host para a pasta de certificados (opcional). Se vazio, usa ./docker/angie/certs relativo ao Compose.
# ANGIE_CERTS_HOST=/caminho/absoluto/para/certs

# --- CLIs de IA (variáveis típicas; consultar documentação oficial de cada ferramenta) ---
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# QWEN_API_KEY=
# CURSOR_API_KEY=
